# Copiar a infra/keycloak/.env (gitignored) si necesitas referencia local.
# Solo desarrollo local — no usar en dev/prod desplegados.

# Admin de Keycloak (master realm)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Cliente OIDC incrementa-backend (debe coincidir con el secret del realm import)
KEYCLOAK_CLIENT_SECRET=dev-incrementa-backend-secret
